<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <!-- Systray Chatbot Icon -->
    <t t-name="quan_ly_van_ban.ChatbotSystrayIcon">
        <div class="o_chatbot_icon_container">
            <a href="#" class="o_chatbot_icon" title="Trợ lý AI Chatbot">
                <i class="fa fa-comments" style="font-size: 18px; color: #7c5bba;"/>
            </a>
        </div>
    </t>

    <!-- Floating Chatbot Window -->
    <t t-name="quan_ly_van_ban.ChatbotWindow">
        <div class="o_chatbot_window">
            <div class="chatbot-header">
                <div class="chatbot-title">
                    <i class="fa fa-android mr-2" style="font-size: 16px; margin-right: 6px;"/> Trợ lý AI (Gemini)
                </div>
                <div class="chatbot-close">
                    <i class="fa fa-times"/>
                </div>
            </div>
            <div class="chatbot-messages">
                <!-- Messages dynamic container -->
            </div>
            <div class="chatbot-footer">
                <input type="text" class="chatbot-input" placeholder="Nhập câu hỏi tại đây..."/>
                <button class="chatbot-send btn btn-primary">
                    <i class="fa fa-paper-plane"/>
                </button>
            </div>
        </div>
    </t>
</templates>
