<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_khach_hang_form_inherit_van_ban" model="ir.ui.view">
            <field name="name">khach_hang.form.inherit.van.ban</field>
            <field name="model">khach_hang</field>
            <field name="inherit_id" ref="quan_ly_khach_hang.view_khach_hang_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Văn bản hành chính liên quan">
                        <separator string="Danh sách Văn bản đến liên quan"/>
                        <field name="van_ban_den_ids" context="{'default_khach_hang_id': active_id}">
                            <tree create="true" edit="true" delete="true">
                                <field name="ten_van_ban"/>
                                <field name="so_van_ban_den"/>
                                <field name="loai_van_ban_id"/>
                                <field name="nhan_vien_xu_ly_id"/>
                                <field name="file_dinh_kem" filename="ten_file" widget="binary"/>
                                <field name="ten_file" invisible="1"/>
                            </tree>
                        </field>
                        
                        <separator string="Danh sách Văn bản đi liên quan" style="margin-top: 20px;"/>
                        <field name="van_ban_di_ids" context="{'default_khach_hang_id': active_id}">
                            <tree create="true" edit="true" delete="true">
                                <field name="ten_van_ban"/>
                                <field name="so_van_ban_di"/>
                                <field name="loai_van_ban_id"/>
                                <field name="nguoi_ky_id"/>
                                <field name="file_dinh_kem" filename="ten_file" widget="binary"/>
                                <field name="ten_file" invisible="1"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
