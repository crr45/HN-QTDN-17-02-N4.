<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_van_ban_den_form" model="ir.ui.view">
            <field name="name">van_ban_den.form</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_ai_analyze" string="Phân tích bằng AI" type="object" class="btn-primary" icon="fa-magic"/>
                        <button name="action_apply_ai_suggestions" string="Áp dụng đề xuất AI" type="object" class="btn-secondary" attrs="{'invisible': [('ai_analysis_status', '!=', 'analyzed')]}" icon="fa-check"/>
                        <field name="ai_analysis_status" widget="statusbar" statusbar_visible="not_analyzed,analyzed,failed"/>
                    </header>
                    <sheet>
                        <div class="oe_read_only" style="font-size:25px">Văn bản đến</div>
                        <group col="4" string="Thông tin chung">
                            <field name="ten_van_ban"/>
                            <field name="so_van_ban_den"/>
                            <field name="so_hieu_van_ban"/>
                            <field name="loai_van_ban_id"/>
                            <field name="don_vi_nhan_id"/>
                            <field name="nhan_vien_xu_ly_id"/>
                            <field name="khach_hang_id" options="{'no_create': True, 'no_open': False}"/>
                            <field name="file_dinh_kem" filename="ten_file"/>
                            <field name="ten_file" invisible="1"/>
                        </group>
                        <notebook>
                            <page string="Nội dung chi tiết">
                                <group>
                                    <field name="mo_ta" placeholder="Nhập nội dung đầy đủ hoặc trích dẫn văn bản ở đây..."/>
                                </group>
                            </page>
                            <page string="Trợ lý AI phân tích">
                                <group>
                                    <group string="Đề xuất từ AI">
                                        <field name="ai_suggested_category_id"/>
                                        <field name="ai_suggested_employee_id"/>
                                    </group>
                                    <group string="Nội dung tóm tắt">
                                        <field name="ai_summary" placeholder="Nhấn nút 'Phân tích bằng AI' để tự động tóm tắt nội dung..."/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_van_ban_den_tree" model="ir.ui.view">
            <field name="name">van_ban_den.tree</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ten_van_ban"/>
                    <field name="so_van_ban_den"/>
                    <field name="so_hieu_van_ban"/>
                    <field name="loai_van_ban_id"/>
                    <field name="don_vi_nhan_id"/>
                    <field name="nhan_vien_xu_ly_id"/>
                    <field name="khach_hang_id"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="van_ban_den_search">
            <field name="name">van_ban_den.search</field>
            <field name="model">van_ban_den</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ten_van_ban"/>
                    <field name="so_van_ban_den"/>
                    <field name="so_hieu_van_ban"/>
                    <field name="loai_van_ban_id"/>
                    <field name="don_vi_nhan_id"/>
                    <field name="nhan_vien_xu_ly_id"/>
                </search>
            </field>
        </record>

        <record id="action_van_ban_den" model="ir.actions.act_window">
            <field name="name">Văn bản đến</field>
            <field name="res_model">van_ban_den</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="van_ban_den_search"/>
        </record>
    </data>
</odoo>
        
    